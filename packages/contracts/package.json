{
  "name": "@repo/contracts",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./warehouse": {
      "types": "./src/warehouse/index.ts",
      "import": "./dist/warehouse/index.js",
      "default": "./dist/warehouse/index.js"
    },
    "./category": {
      "types": "./src/category/index.ts",
      "import": "./dist/category/index.js",
      "default": "./dist/category/index.js"
    },
    "./brand": {
      "types": "./src/brand/index.ts",
      "import": "./dist/brand/index.js",
      "default": "./dist/brand/index.js"
    },
    "./product": {
      "types": "./src/product/index.ts",
      "import": "./dist/product/index.js",
      "default": "./dist/product/index.js"
    },
    "./product-variant": {
      "types": "./src/product-variant/index.ts",
      "import": "./dist/product-variant/index.js",
      "default": "./dist/product-variant/index.js"
    },
    "./product-price": {
      "types": "./src/product-price/index.ts",
      "import": "./dist/product-price/index.js",
      "default": "./dist/product-price/index.js"
    },
    "./common": {
      "types": "./src/common/index.ts",
      "import": "./dist/common/index.js",
      "default": "./dist/common/index.js"
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
