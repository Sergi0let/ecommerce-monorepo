{
  "name": "@repo/database",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio --port 5555",
    "check-types": "pnpm db:generate && tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "prisma": "^7.8.0",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  } 
}